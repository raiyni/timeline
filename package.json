  "author": "Ron Young",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/raiyni/timeline/issues"
  },
  "homepage": "https://github.com/raiyni/timeline",
  "main": "dist/timeline.js",
  "css": "dist/timeline.css",
  "types": "types/index.d.ts",
  "devDependencies": {
